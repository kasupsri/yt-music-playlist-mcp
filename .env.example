# Google OAuth client configured for an installed/web app.
# Enable the YouTube Data API in the same Google Cloud project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Defaults to 3987.
GOOGLE_REDIRECT_PORT=3987

# Optional. Defaults to GOOGLE_REDIRECT_PORT or 3987.
# Use the same port for Codex MCP OAuth and Google OAuth callback.
MCP_HTTP_PORT=3987

# Optional. Defaults to ./.local relative to the current working directory.
YOUTUBE_MUSIC_MCP_HOME=

# Optional. Used by the unofficial YouTube Music adapter.
YTMUSIC_USER_AGENT=Mozilla/5.0
